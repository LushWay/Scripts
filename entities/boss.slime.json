{
  "format_version": "1.13.0",
  "minecraft:entity": {
    "description": {
      "identifier": "lw:slime",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "lw:big": {
        "minecraft:collision_box": {
          "width": 1,
          "height": 1
        },
        "minecraft:attack": {
          "damage": 4
        },
        "minecraft:scale": {
          "value": 4
        }
      },

      "lw:normal": {
        "minecraft:collision_box": {
          "width": 0.5,
          "height": 0.5
        },
        "minecraft:movement": {
          "value": 0.3
        },
        "minecraft:attack": {
          "damage": 1
        },
        "minecraft:scale": {
          "value": 2
        }
      },

      "minecraft:slime_calm": {
        "minecraft:movement.jump": {
          "jump_delay": [0.5, 1.5]
        }
      },
      "minecraft:slime_aggressive": {
        "minecraft:movement.jump": {
          "jump_delay": [0.16, 0.5]
        }
      }
    },

    "components": {
      // General boss options
      "minecraft:loot": {
        "table": "loot_tables/empty.json"
      },
      "minecraft:nameable": {
        "allow_name_tag_renaming": true,
        "always_show": true
      },
      "minecraft:boss": {
        "should_darken_sky": false,
        "hud_range": 40
      },

      // Entity specific options
      "minecraft:collision_box": {
        "width": 1.04,
        "height": 1.04
      },

      "minecraft:behavior.nearest_attackable_target": {
        "priority": 5,
        "reselect_targets": true,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                }
              ]
            },
            "max_dist": 30
          }
        ],
        "must_see": true
      },

      "minecraft:health": {
        "value": 500,
        "max": 500
      },
      "minecraft:attack": {
        "damage": 8
      },
      "minecraft:movement": {
        "value": 0.9
      },
      "minecraft:scale": {
        "value": 6
      },

      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? query.variant : 0"
      },
      "minecraft:type_family": {
        "family": ["slime", "monster", "mob"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true
      },
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement.jump": {
        "jump_delay": [0.5, 1.5]
      },
      "minecraft:on_target_acquired": {
        "event": "minecraft:become_aggressive",
        "target": "self"
      },
      "minecraft:on_target_escape": {
        "event": "minecraft:become_calm",
        "target": "self"
      },
      "minecraft:behavior.slime_float": {
        "priority": 1
      },
      "minecraft:behavior.slime_attack": {
        "priority": 3
      },
      "minecraft:behavior.slime_random_direction": {
        "priority": 4
      },
      "minecraft:behavior.slime_keep_on_jumping": {
        "priority": 5
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      }
    },

    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["minecraft:slime_calm"]
        }
      },
      "minecraft:become_calm": {
        "add": {
          "component_groups": ["minecraft:slime_calm"]
        }
      },
      "minecraft:become_aggressive": {
        "add": {
          "component_groups": ["minecraft:slime_aggressive"]
        }
      },
      "lw:slime_big": {
        "add": {
          "component_groups": ["minecraft:slime_aggressive", "minecraft:slime_large", "lw:big"]
        }
      },
      "lw:slime_normal": {
        "add": {
          "component_groups": ["minecraft:slime_aggressive", "minecraft:slime_medium", "lw:normal"]
        }
      }
    }
  }
}
